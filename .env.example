TZ=Asia/Shanghai

# Panel auth
PANEL_AUTH_PASSWORD=change-panel-password
PANEL_JWT_SECRET=change-this-to-a-long-random-string
PANEL_API_BIND=0.0.0.0
PANEL_API_PORT=16824
PANEL_STATE_DIR=/data/panel-state
PANEL_DB_FILE=/data/panel-state/panel.sqlite
PANEL_ALLOW_RAW_RCON=false

# Palworld container and data paths
PALWORLD_CONTAINER=palworld-server
PALWORLD_DATA_DIR=/palworld
PALWORLD_SAVES_DIR=/palworld/Pal/Saved/SaveGames
PALWORLD_BACKUP_DIR=/palworld/backups
PALWORLD_COMPOSE_DIR=/stack

# Palworld public game address
PALWORLD_PUBLIC_DOMAIN=pal.example.com
PALWORLD_PUBLIC_IP=
PALWORLD_PORT=8211
PALWORLD_QUERY_PORT=27015

# Palworld management ports, keep local/internal only
PALWORLD_RCON_HOST=palworld
PALWORLD_RCON_PORT=25575
PALWORLD_REST_PORT=8212

# Game settings
PALWORLD_SERVER_NAME=Palworld Dedicated Server
PALWORLD_SERVER_DESCRIPTION=Managed by Palworld Ops
PALWORLD_PLAYERS=32
PALWORLD_SERVER_PASSWORD=change-game-password
PALWORLD_ADMIN_PASSWORD=change-admin-password
PALWORLD_COMMUNITY=false
PALWORLD_RCON_ENABLED=true
PALWORLD_REST_API_ENABLED=false
PALWORLD_EXP_RATE=1
PALWORLD_CAPTURE_RATE=1
PALWORLD_SPAWN_RATE=1
PALWORLD_COLLECTION_DROP_RATE=1
PALWORLD_ENEMY_DROP_RATE=1
PALWORLD_EGG_HATCHING_HOURS=72
PALWORLD_AUTO_SAVE_SPAN=30
PALWORLD_DEATH_PENALTY=All
PALWORLD_BASE_CAMP_WORKER_MAX=15
PALWORLD_GUILD_PLAYER_MAX=20
PALWORLD_BASE_CAMP_MAX_IN_GUILD=4
PALWORLD_CROSSPLAY_PLATFORMS=Steam,Xbox,PS5,Mac
PALWORLD_AUTO_PAUSE_ENABLED=false
PALWORLD_PLAYER_LOGGING_ENABLED=true
PALWORLD_DISCORD_WEBHOOK_ENABLED=false
PALWORLD_TARGET_MANIFEST_ID=

# Automation
PALWORLD_UPDATE_ON_BOOT=true
PALWORLD_AUTO_UPDATE_ENABLED=true
PALWORLD_AUTO_UPDATE_CRON="0 4 * * *"
PALWORLD_AUTO_REBOOT_ENABLED=true
PALWORLD_AUTO_REBOOT_CRON="0 5 * * *"
PALWORLD_BACKUP_ENABLED=true
PALWORLD_BACKUP_CRON="0 * * * *"
PALWORLD_BACKUP_RETENTION=72

# Frontend local mock mode. Leave false for real backend.
VITE_USE_MOCK_API=false
